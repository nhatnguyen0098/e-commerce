USER_DATABASE_URL=postgresql://admin:12345@localhost:5432/ecom_user?schema=public
PRODUCT_DATABASE_URL=postgresql://admin:12345@localhost:5433/ecom_product?schema=public
ORDER_DATABASE_URL=postgresql://admin:12345@localhost:5434/ecom_order?schema=public
PAYMENT_DATABASE_URL=postgresql://admin:12345@localhost:5435/ecom_payment?schema=public

# API gateway: CORS (comma-separated origins, or "reflect" to mirror request Origin)
# API_GATEWAY_CORS_ORIGIN=reflect
# API_GATEWAY_CORS_ORIGIN=http://localhost:5173
# API_GATEWAY_CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# API gateway: httpOnly JWT cookie (optional; defaults shown)
# AUTH_ACCESS_TOKEN_COOKIE_MAX_AGE_MS=3600000
# AUTH_ACCESS_TOKEN_COOKIE_SECURE=false
# AUTH_ACCESS_TOKEN_COOKIE_SAME_SITE=lax

# Kafka brokers for inter-service messaging (comma-separated)
# KAFKA_BROKERS=127.0.0.1:9092
KAFKA_BROKERS=127.0.0.1:9092

# OpenTelemetry / Grafana Cloud
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAMESPACE=e-commerce
GRAFANA_CLOUD_USER_ID=REPLACE_WITH_USER_ID
GRAFANA_CLOUD_API_KEY=REPLACE_WITH_API_KEY
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-southeast-1.grafana.net/otlp
GRAFANA_CLOUD_PROM_REMOTE_WRITE_ENDPOINT=https://prometheus-prod-xx.grafana.net/api/prom/push
GRAFANA_CLOUD_LOKI_ENDPOINT=https://logs-prod-xx.grafana.net/loki/api/v1/push
