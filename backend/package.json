{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build api-gateway && nest build user-service && nest build auth-service && nest build product-service && nest build order-service && nest build payment-service && tsc-alias -p apps/api-gateway/tsconfig.app.json && tsc-alias -p apps/user-service/tsconfig.app.json && tsc-alias -p apps/auth-service/tsconfig.app.json && tsc-alias -p apps/product-service/tsconfig.app.json && tsc-alias -p apps/order-service/tsconfig.app.json && tsc-alias -p apps/payment-service/tsconfig.app.json",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start api-gateway",
    "start:dev": "nest start api-gateway --watch",
    "start:debug": "nest start api-gateway --debug --watch",
    "start:prod": "node dist/apps/api-gateway/apps/api-gateway/src/main.js",
    "start:user-service": "nest start user-service",
    "start:user-service:dev": "nest start user-service --watch",
    "start:auth-service": "nest start auth-service",
    "start:auth-service:dev": "nest start auth-service --watch",
    "start:product-service": "nest start product-service",
    "start:product-service:dev": "nest start product-service --watch",
    "start:order-service": "nest start order-service",
    "start:order-service:dev": "nest start order-service --watch",
    "start:payment-service": "nest start payment-service",
    "start:payment-service:dev": "nest start payment-service --watch",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "USER_DATABASE_URL=${USER_DATABASE_URL:-postgresql://build:build@127.0.0.1:5432/build?schema=public} npx prisma generate --schema=apps/user-service/prisma/schema.prisma && PRODUCT_DATABASE_URL=${PRODUCT_DATABASE_URL:-postgresql://build:build@127.0.0.1:5432/build?schema=public} npx prisma generate --schema=apps/product-service/prisma/schema.prisma && ORDER_DATABASE_URL=${ORDER_DATABASE_URL:-postgresql://build:build@127.0.0.1:5432/build?schema=public} npx prisma generate --schema=apps/order-service/prisma/schema.prisma && PAYMENT_DATABASE_URL=${PAYMENT_DATABASE_URL:-postgresql://build:build@127.0.0.1:5432/build?schema=public} npx prisma generate --schema=apps/payment-service/prisma/schema.prisma",
    "postinstall": "npm run prisma:generate",
    "prisma:seed": "npm run prisma:seed:product",
    "prisma:seed:product": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' apps/product-service/prisma/seed.ts",
    "k6:smoke": "k6 run k6/smoke.js",
    "k6:load-catalog": "k6 run k6/load-catalog.js",
    "k6:smoke:docker": "docker run --rm -v \"$PWD/k6:/k6:ro\" -e BASE_URL=\"${BASE_URL:-http://host.docker.internal:3000}\" grafana/k6:latest run /k6/smoke.js",
    "k6:load-catalog:docker": "docker run --rm -v \"$PWD/k6:/k6:ro\" -e BASE_URL=\"${BASE_URL:-http://host.docker.internal:3000}\" grafana/k6:latest run /k6/load-catalog.js"
  },
  "prisma": {},
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@contracts/(.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@database/(.*)$": "<rootDir>/libs/database/src/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
