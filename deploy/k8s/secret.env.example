# Copy to secret.env, fill values, then:
# kubectl create secret generic e-commerce-secrets -n e-commerce --from-env-file=secret.env --dry-run=client -o yaml | kubectl apply -f -
USER_DATABASE_URL=postgresql://admin:REPLACE@postgres-user:5432/ecom_user?schema=public
PRODUCT_DATABASE_URL=postgresql://admin:REPLACE@postgres-product:5432/ecom_product?schema=public
ORDER_DATABASE_URL=postgresql://admin:REPLACE@postgres-order:5432/ecom_order?schema=public
PAYMENT_DATABASE_URL=postgresql://admin:REPLACE@postgres-payment:5432/ecom_payment?schema=public
AUTH_JWT_SECRET=replace-with-long-random-secret
